CONFIG_TARGET_ipq60xx=y
CONFIG_TARGET_ipq60xx_generic=y
CONFIG_TARGET_ipq60xx_generic_DEVICE_xiaomi_redmi-router-ax5=y
CONFIG_TARGET_BOARD="ipq60xx"
CONFIG_TARGET_SUBTARGET="generic"
CONFIG_TARGET_PROFILE="DEVICE_xiaomi_redmi-router-ax5"
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"

# 核心 TLS/HTTPS 支持 (用于 MCP 协议和云端 AI 通讯)
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_curl=y

# 内存优化 (256MB RAM 必须开启 zRAM)
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-config=y

# 插件选择 (保持精简以满足 35MB 固件限制)
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y

# 极致压缩减小体积
CONFIG_USE_UPX=y
CONFIG_STRIP_KERNEL_EXPORTS=y
